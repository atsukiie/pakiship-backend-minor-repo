{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/[[...slug]]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/[[...slug]]/page.js"
    ],
    "/api/parcel-drafts/step-1/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/parcel-drafts/step-1/route.js"
    ],
    "/api/parcel-drafts/[draftId]/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/parcel-drafts/[draftId]/route.js"
    ],
    "/api/parcel-drafts/[draftId]/items/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/parcel-drafts/[draftId]/items/route.js"
    ],
    "/api/parcel-drafts/[draftId]/items/[itemId]/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/parcel-drafts/[draftId]/items/[itemId]/route.js"
    ]
  }
}